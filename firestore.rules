rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // ===================================
    // MATCHES COLLECTION
    // ===================================
    match /matches/{matchId} {
      // Anyone can read matches
      allow read: if true;
      
      // Only authenticated users can create matches (admin check on client)
      allow create: if request.auth != null;
      
      // Update rules: 
      // - Regular updates allowed for authenticated users
      // - MVP field can only be set by server/cloud functions OR when voting is closed
      allow update: if request.auth != null
        && (
          // If not changing mvp, allow update
          !request.resource.data.diff(resource.data).affectedKeys().hasAny(['mvp'])
          // OR if mvp was null and votingClosed is being set to true
          || (resource.data.mvp == null && request.resource.data.votingClosed == true)
        );
      
      // Only authenticated users can delete
      allow delete: if request.auth != null;
      
      // ===================================
      // VOTES SUBCOLLECTION
      // ===================================
      match /votes/{oderId} {
        // Anyone can read votes (for MVP calculation)
        allow read: if true;
        
        // Vote creation rules:
        // 1. User must be authenticated
        // 2. Document ID must match the user's UID (one vote per user)
        // 3. User can't already have a vote document
        // 4. Vote must include player and votedAt fields
        allow create: if request.auth != null 
          && oderId == request.auth.uid
          && !exists(/databases/$(database)/documents/matches/$(matchId)/votes/$(request.auth.uid))
          && request.resource.data.keys().hasAll(['player', 'votedAt'])
          && request.resource.data.player is string
          && request.resource.data.player.size() > 0;
        
        // Votes cannot be updated or deleted
        allow update, delete: if false;
      }
    }

    // ===================================
    // FANTASY TEAMS COLLECTION
    // ===================================
    match /fantasyTeams/{userId} {
      // All authenticated users can read all teams (for leaderboard)
      allow read: if request.auth != null;
      
      // Users can only write their own team
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    // ===================================
    // GAMEWEEKS COLLECTION
    // ===================================
    // ===================================
    // GAMEWEEKS COLLECTION
    // ===================================
    match /gameweeks/{gameweekId} {
      // Everyone can read gameweeks
      allow read: if true;
      
      // Only authenticated users can create/update/delete
      allow write: if request.auth != null;

      // Allow access to squads subcollection for snapshots
      match /squads/{squadId} {
          allow read: if true;
          allow write: if request.auth != null;
      }
    }

    // ===================================
    // MATCH STATS COLLECTION (Nested Structure)
    // ===================================
    // Matches match_stats/{gameweekId} AND match_stats/{gameweekId}/players/{playerId}
    match /match_stats/{document=**} {
      // Everyone can read match stats (for leaderboard)
      allow read: if true;
      
      // Only authenticated users can write (admin check on client)
      allow write: if request.auth != null;
    }

    // ===================================
    // PLAYER VOTES COLLECTION
    // ===================================
    match /player_votes/{voteId} {
      // Everyone can read votes (for average calculation)
      allow read: if true;
      
      // Vote creation rules:
      // 1. User must be authenticated
      // 2. Vote must include required fields
      // 3. User can only create votes with their own userId
      allow create: if request.auth != null
        && request.resource.data.keys().hasAll(['gameweekId', 'playerId', 'userId', 'rating', 'votedAt'])
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.rating >= 1.0
        && request.resource.data.rating <= 10.0;
      
      // Votes cannot be updated or deleted
      allow update, delete: if false;
    }

    // ===================================
    // PLAYERS COLLECTION
    // ===================================
    match /players/{playerId} {
      // Everyone can read player data
      allow read: if true;
      
      // Only authenticated users can write (admin check on client)
      allow write: if request.auth != null;
    }
  }
}
